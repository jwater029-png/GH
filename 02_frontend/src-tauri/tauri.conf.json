{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "星网",
  "version": "0.1.0",
  "identifier": "com.starnet.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "node sync-dist.js",
    "beforeBuildCommand": "node sync-dist.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "星网 · 个人偏好",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
